# Planning by reference: instead of writing the plan inline, the loop pulls
# it from an Archon project. Archon supplies the plan (the tasks/order);
# Loop just executes it with Claude Code and feeds results back each cycle.
#
# Because the plan lives in Archon, you keep this file small: no inline
# task list to maintain — update the plan in Archon and the loop follows it.
# Run with ARCHON_URL set so the runtime can reach your Archon instance:
#   loop run examples/methods/plan-from-archon.loop

loop "work the billing project":
  goal: the billing project's tasks are done and its tests pass
  plan from the archon project "billing"   # Archon supplies the plan
  look at: src/billing, and the last failure   # context the agent reads each cycle

  each cycle: act, then observe   # no inline plan step — Archon already planned it
  done when "pnpm test billing" passes   # objective gate: real command must exit 0
  when it fails: reflect on the failing task, then plan again
  after 6 tries: stop and warn "billing tasks are thrashing"   # don't loop forever
