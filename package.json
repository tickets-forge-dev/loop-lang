{
  "name": "loop-lang",
  "private": true,
  "version": "0.1.0",
  "description": "LoopFlow — an open, natural-language DSL for loop engineering. Describe staged, self-correcting, human-gated agent workflows; press Play to run them on Claude Code.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/parser",
    "packages/stdlib",
    "packages/viz",
    "packages/runtime",
    "packages/cli",
    "packages/vscode"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:playground": "esbuild scripts/playground-entry.ts --bundle --format=iife --global-name=Loop --outfile=docs/playground/loop-lang.js --minify",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "esbuild": "^0.21.5",
    "typescript": "5.5.4"
  }
}
