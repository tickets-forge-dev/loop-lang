{
  "name": "loop-lang",
  "private": true,
  "version": "0.1.0",
  "description": "Loop — an open, natural-language DSL for loop engineering. Describe staged, self-correcting, human-gated agent workflows; press Play to run them on Claude Code.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/parser",
    "packages/stdlib",
    "packages/export-archon",
    "packages/generate",
    "packages/viz",
    "packages/runtime",
    "packages/vscode",
    "packages/studio"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "typescript": "5.5.4"
  }
}
