{
  "name": "@loop/studio",
  "version": "0.1.0",
  "description": "Three-way interactive shell for Loop: chat (generate) + editable .loop text (parse) + live graph (viz), bound to the loop-spec IR. Press Run to stream the trace into the graph.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": "./dist/index.js" },
  "bin": { "loop-studio": "dist/cli.js" },
  "files": ["dist", "src"],
  "dependencies": {
    "@loop/parser": "0.1.0",
    "@loop/generate": "0.1.0",
    "@loop/viz": "0.1.0",
    "@loop/runtime": "0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.js"
  }
}
